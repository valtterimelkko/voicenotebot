# VoiceNote Bot Environment Variables
# Copy this file to .env and fill in your actual values

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Kimi API Configuration
KIMI_API_KEY=your_kimi_api_key_here

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Transcription Provider
# Options: whisper (primary, local), openai (fallback via API)
TRANSCRIPTION_PROVIDER=whisper

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Whisper Service URL (used as fallback when TRANSCRIPTION_PROVIDER=whisper or OpenAI fails)
WHISPER_URL=http://whisper:9000/asr

# Webhook Configuration
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000
WEBHOOK_SECRET=your_random_secret_for_webhook_verification

# Application Settings
LOG_LEVEL=INFO
MAX_VOICE_DURATION_MINUTES=5
MAX_FILE_SIZE_MB=20
WORKER_TIMEOUT_SECONDS=600

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAYS_SECONDS=60,300,600
